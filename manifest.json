{
  "manifest_version": 3,
  "name": "Blindly",
  "version": "1.0",
  "description": "Hide non-educational YouTube videos.",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Blindly"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}